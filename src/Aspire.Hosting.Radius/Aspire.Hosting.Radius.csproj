<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>$(DefaultTargetFramework)</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageTags>aspire integration hosting radius kubernetes portable-resources</PackageTags>
    <Description>Radius compute environment support for .NET Aspire, enabling portable resource deployment via rad CLI.</Description>
    <!-- New package — no baseline exists on NuGet yet -->
    <DisablePackageBaselineValidation>true</DisablePackageBaselineValidation>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aspire.Hosting\Aspire.Hosting.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Aspire.Hosting.Radius.Tests" />
  </ItemGroup>

</Project>
